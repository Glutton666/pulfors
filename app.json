{
  "expo": {
    "name": "PulFors",
    "slug": "pulfors",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "pulfors",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulfors.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "마이크를 사용하여 악기 음정을 감지하고 튜닝합니다.",
        "NSLocationWhenInUseUsageDescription": "연습실 위치를 저장하고 가까운 연습실을 찾기 위해 위치를 사용합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "연습실 위치를 저장하고 가까운 연습실을 찾기 위해 위치를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "프로필 사진과 이미지를 선택하기 위해 사진 라이브러리에 접근합니다.",
        "NSCameraUsageDescription": "프로필 사진을 촬영하기 위해 카메라를 사용합니다.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pulfors.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "pulfors"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0D1117",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "마이크를 사용하여 악기 음정을 감지하고 튜닝합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#0D1117",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "연습실 위치를 저장하고 가까운 연습실을 찾기 위해 위치를 사용합니다.",
          "locationAlwaysAndWhenInUsePermission": "연습실 위치를 저장하고 가까운 연습실을 찾기 위해 위치를 사용합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진과 이미지를 선택하기 위해 사진 라이브러리에 접근합니다.",
          "cameraPermission": "프로필 사진을 촬영하기 위해 카메라를 사용합니다."
        }
      ],
      "onnxruntime-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba0bcd08-da0d-4317-a8e2-e72ed4bb3411"
      }
    }
  }
}
